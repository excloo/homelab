${join("\n", compact([
  service.features.pushover ? "PUSHOVER_APPLICATION_TOKEN=\"${service.pushover_application_token_sensitive}\"" : "",
  service.features.pushover ? "PUSHOVER_USER_KEY=\"${service.pushover_user_key_sensitive}\"" : "",
  service.features.resend ? "RESEND_API_KEY=\"${service.resend_api_key_sensitive}\"" : "",
  service.features.tailscale ? "TAILSCALE_AUTH_KEY=\"${service.tailscale_auth_key_sensitive}\"" : ""
]))}
